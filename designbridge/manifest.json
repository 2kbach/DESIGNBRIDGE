{
  "manifest_version": 3,
  "name": "DesignBridge",
  "version": "0.4.0",
  "description": "Select elements visually, describe changes, send to Claude Code",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:7890/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-inspect": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Toggle inspect mode"
    }
  }
}
